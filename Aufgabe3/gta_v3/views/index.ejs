<!DOCTYPE html>

<!-- File origin: VS1LAB A1a -->

<html lang="en">

<head>
    <link rel='stylesheet' href='https://unpkg.com/leaflet@1.9.4/dist/leaflet.css'
        integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
        crossorigin=""/>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
        integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
        crossorigin=""></script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GeoTagApp</title>
    <link rel="stylesheet" href="./stylesheets/style.css" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>

<body>
    <header class="header">
        <img src="./images/location.png" class="header__image" alt="an image of a map and location">
        <h1 class="header__title">GeoTagApp</h1>
        <nav class="header__navigation">
            <a href="#">About</a> | <a href="#">Help</a> | <a href="/">Home</a>
        </nav>
    </header>

    <main class="main">
        <section class="main__tagging tagging">
            <h2>Tagging</h2>

            <!-- ############### VS1Lab 1a Form 1 Start -->
            <form id="tag-form" action="/tagging" method="post">
                <fieldset class="tagging__fieldset">
                    <legend>Create a new GeoTag</legend>
                    <label for="tagging_latitude_input">Latitude:</label>
                    <input id="tagging_latitude_input" name="latitude" value="<%= locals.latitude || '' %>" readonly>
                    <label for="tagging_longitude_input">Longitude:</label>
                    <input id="tagging_longitude_input" name="longitude" value="<%= locals.longitude || '' %>" readonly>
                    <label for="tagging_name_input">Name:</label>
                    <input id="tagging_name_input" name="name" placeholder="e.g. HKA Campus" required maxlength="10" pattern="[A-Za-z]{1,10}">
                    <label for="tagging_hashtag_input">Hashtag:</label>
                    <input id="tagging_hashtag_input" name="hashtag" placeholder="e.g. Studium" maxlength="11" pattern="#[A-Za-z]{1,10}">
                    <button id="tagging_create_geotag_button" type="submit">Create GeoTag</button>
                </fieldset>
            </form>
            <!-- ############### VS1Lab 1a Form 1 End -->

        </section>

        <section class="main__discovery discovery">
            <h2 class="discovery__title">Discovery</h2>

            <!-- ############### VS1Lab 1a Form 2 Start -->
            <form class="discovery__search" id="discoveryFilterForm" action="/discovery" method="post">
                <fieldset class="discovery__fieldset">
                    <legend>Search for GeoTags</legend>
                    <label for="discovery_search_input">Search term:</label>
                    <input id="discovery_search_input" name="keyword" placeholder="e.g. Karlsruhe">
                    <input type="hidden" id="discovery_longitude_input" name="dlongitude" value="<%= locals.longitude || '' %>" readonly>
                    <input type="hidden" id="discovery_latitude_input" name="dlatitude" value="<%= locals.latitude || '' %>" readonly>
                    <button id="discovery_search_button" type="submit">Search</button>
                </fieldset>
            </form>
            <!-- ############### VS1Lab 1a Form 2 End -->

            <div class="discovery__wrapper">
                <div class="discovery__taglist">
                    <ul class="discovery__results" id="discoveryResults">
                        <% if (taglist !== undefined) taglist.forEach(function(gtag) { %>
                            <li><%= gtag.name %> ( <%= gtag.latitude %>,<%= gtag.longitude %>) <%= gtag.hashtag %> </li>
                        <% }); %>
                    </ul>
                </div>

                <div id="map" class="discovery__map" data-tags="<%= JSON.stringify(taglist) %>">
                    <img src="./images/mapview.jpg" alt="a map with locations" id="mapView" />
                    <p id="mapPlaceholder">Result map</p>
                </div>
            </div>
        </section>

    </main>

    <footer class="footer">
        <span>(c) 2021/22 HKA_IWI_VSYS</span>
    </footer>

    <script src="./javascripts/geotagging.js"></script>
    <script src="./javascripts/location-helper.js"></script>
    <script src="./javascripts/map-manager.js"></script>

</body>

</html>
